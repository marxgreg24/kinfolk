    {
      "name": "Auth",
      "item": [
        {
          "name": "Sync User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{clerk_token}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"user@example.com\",\"full_name\":\"Nakato Rose\",\"clan_id\":\"{{clan_id}}\"}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/sync",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "sync"]
            }
          }
        }
      ]
    },
